# Milotic Configuration - copy to .env for local development

# --- Backend Connection ---
# Base URL for the Go backend, including handshake and API endpoints
GO_BACKEND_URL=https://api.example.com

# --- Crypto & Handshake Settings ---
# Master toggle for the encryption layer. Set to "false" to disable.
CRYPTO_ENABLED=true

# Client ID sent in the X-API-Client-Id header for handshake and encrypted calls
API_CLIENT_ID="your-client-id"

# 32+ character AES session secret. This is held by the client and NEVER transmitted in plaintext.
API_SESSION_SECRET="a-very-secure-32-byte-secret-key"

# DEV FALLBACK ONLY: RSA public key (base64-encoded DER body).
# Use this only if the handshake endpoint is unavailable in a dev environment.
# In production, this should be empty, and the key fetched via handshake.
API_RSA_PUBLIC_KEY=""

# Path for the public key handshake endpoint
HANDSHAKE_PATH="/handshake/get-public-key"

# Cache TTL for the fetched public key (in seconds)
HANDSHAKE_PUBLIC_KEY_TTL_SECONDS=3600

# Header name for the client ID
HANDSHAKE_CLIENT_ID_HEADER="X-API-Client-Id"

# --- Logging ---
LOG_LEVEL="INFO"
