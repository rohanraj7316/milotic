# Milotic Configuration - copy to .env for local development

# --- Per-category backend URLs ---
# Set the base URL for each service category. Leave blank to disable that category.
MARKET_BACKEND_URL=https://market-api.example.com
ACCOUNT_BACKEND_URL=https://account-api.example.com
TRADING_BACKEND_URL=https://trading-api.example.com
RESEARCH_BACKEND_URL=https://research-api.example.com

# --- Crypto & Handshake Settings ---
# Master toggle for the encryption layer. Set to "false" to disable for local dev.
CRYPTO_ENABLED=true

# Client ID sent in the X-API-Client-Id header for handshake and encrypted calls
API_CLIENT_ID="your-client-id"

# 32+ character AES session secret. Client-held, never transmitted in plaintext.
API_SESSION_SECRET="a-very-secure-32-byte-secret-key"

# DEV FALLBACK ONLY: RSA public key (base64-encoded DER body).
# Leave blank in production — key is fetched from the backend via handshake.
API_RSA_PUBLIC_KEY=""

# Path for the public key handshake endpoint
HANDSHAKE_PATH="/handshake/get-public-key"

# Cache TTL for the fetched public key (seconds)
HANDSHAKE_PUBLIC_KEY_TTL_SECONDS=3600

# Header name for the client ID
HANDSHAKE_CLIENT_ID_HEADER="X-API-Client-Id"

# --- Resilience ---
# Max concurrent in-flight requests per backend client
MAX_CONCURRENT_REQUESTS=20

# Number of consecutive failures before the circuit breaker opens
CIRCUIT_BREAKER_THRESHOLD=5

# --- Logging ---
LOG_LEVEL="INFO"
